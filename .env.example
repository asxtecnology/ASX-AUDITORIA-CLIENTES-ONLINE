# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/SEU_PROJECT_ID/settings/database
DATABASE_URL=postgresql://postgres.SEU_PROJECT_ID:SUA_SENHA@aws-0-us-east-2.pooler.supabase.com:6543/postgres

# ─── Authentication ───────────────────────────────────────────────────────────
# Segredo para assinar cookies de sessão JWT (mínimo 32 caracteres)
JWT_SECRET=seu-segredo-jwt-minimo-32-caracteres-aqui

# ─── Manus OAuth ─────────────────────────────────────────────────────────────
# Configurado automaticamente pela plataforma Manus
VITE_APP_ID=seu-app-id-manus
OAUTH_SERVER_URL=https://api.manus.im

# ─── Owner Info ───────────────────────────────────────────────────────────────
# Configurado automaticamente pela plataforma Manus
OWNER_OPEN_ID=seu-open-id

# ─── Manus Built-in APIs ──────────────────────────────────────────────────────
# Configurado automaticamente pela plataforma Manus
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=sua-chave-api-manus

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
